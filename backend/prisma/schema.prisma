generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  expenses     Expense[]
  budgets      Budget[]
  insights     Insight[]
}

model Expense {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  amount        Float
  category      String
  date          DateTime
  description   String
  paymentMethod String
  billImageUrl  String?
  createdAt     DateTime @default(now())
}

model Budget {
  id           String @id @default(uuid())
  userId       String
  user         User   @relation(fields: [userId], references: [id])
  monthlyLimit Float
  month        Int
  year         Int
}

model Insight {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  type      String   // e.g., CRITICAL, WARNING, INFO
  category  String   // e.g., LEAK, SPIKE, BUDGET
  isAlert   Boolean  @default(false)
  status    String   @default("ACTIVE") // ACTIVE, RESOLVED, DISMISSED
  createdAt DateTime @default(now())
}
